# Clé API Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Modèles (optionnels — valeurs par défaut ci-dessous)
AGENT_MODEL=claude-sonnet-4-6
ORCHESTRATOR_MODEL=claude-opus-4-8

# Itérations par phase (optionnelles — défaut: 1)
ITERATIONS_BRAINSTORMING=1
ITERATIONS_THESIS=1
ITERATIONS_ANTITHESIS=1
ITERATIONS_SYNTHESIS=1

# Questions par défaut (format JSON, optionnel)
DEFAULT_QUESTIONS=["Votre question ici"]

# Répertoire des agents du débat (obligatoire en pratique) — doit toujours pointer vers
# domains/<domaine>/agents. Aucun agent propre à un domaine ne doit être défini à la
# racine du projet (agents/) : ce répertoire, s'il existe, est réservé à des agents
# transverses (recherche, pré-traitement de données), jamais des participants au débat.
AGENTS_DIR=domains/finance/agents
