# Clé API Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Modèles (optionnels — valeurs par défaut ci-dessous)
AGENT_MODEL=claude-sonnet-4-6
ORCHESTRATOR_MODEL=claude-opus-4-8

# Itérations par phase (optionnelles — défaut: 1)
ITERATIONS_BRAINSTORMING=1
ITERATIONS_THESIS=1
ITERATIONS_ANTITHESIS=1
ITERATIONS_SYNTHESIS=1

# Questions par défaut (format JSON, optionnel)
DEFAULT_QUESTIONS=["Votre question ici"]

# Répertoire des agents (optionnel — défaut: agents/)
# Pointer vers domains/finance/agents pour le domaine finance
AGENTS_DIR=agents
